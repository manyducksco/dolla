{
  "name": "@manyducks.co/dolla",
  "version": "3.0.0-rc.1",
  "description": "A fast, batteries-included JavaScript framework with a React-like API and the power of Signals.",
  "main": "dist/index.js",
  "types": "dist/core/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manyducksco/dolla.git"
  },
  "scripts": {
    "test": "vitest",
    "build:esbuild": "tsc && node build.js",
    "build": "vite build && tsc",
    "start": "tsc --watch",
    "prepublishOnly": "NODE_ENV=production npm run build"
  },
  "keywords": [
    "web app",
    "front end framework",
    "functional",
    "reactive state"
  ],
  "author": "tony@manyducks.co",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./http": {
      "import": "./dist/http.js",
      "types": "./dist/http/index.d.ts"
    },
    "./router": {
      "import": "./dist/router.js",
      "types": "./dist/router/index.d.ts"
    },
    "./translate": {
      "import": "./dist/translate.js",
      "types": "./dist/translate/index.d.ts"
    },
    "./jsx-runtime": {
      "import": "./dist/jsx-runtime.js",
      "types": "./jsx-runtime.d.ts"
    },
    "./jsx-dev-runtime": {
      "import": "./dist/jsx-dev-runtime.js",
      "types": "./jsx-dev-runtime.d.ts"
    }
  },
  "files": [
    "dist",
    "*.d.ts"
  ],
  "dependencies": {
    "alien-signals": "^2.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "csstype": "^3.2.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
