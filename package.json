{
  "name": "@manyducks.co/dolla",
  "version": "4.4.0",
  "description": "A fast, batteries-included JavaScript framework with a React-inspired API and the power of signals.",
  "main": "dist/index.js",
  "types": "dist/core/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manyducksco/dolla.git"
  },
  "scripts": {
    "test": "vitest",
    "build:esbuild": "tsc && node build.js",
    "build": "vite build && tsc",
    "start": "tsc --watch",
    "prepublishOnly": "NODE_ENV=production npm run build"
  },
  "keywords": [
    "web app",
    "front end framework",
    "functional",
    "reactive state",
    "signals"
  ],
  "author": "tony@manyducks.co",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./router": {
      "import": "./dist/router.js",
      "types": "./dist/router/index.d.ts"
    },
    "./translate": {
      "import": "./dist/translate.js",
      "types": "./dist/translate/index.d.ts"
    },
    "./http": {
      "import": "./dist/http.js",
      "types": "./dist/http/index.d.ts"
    },
    "./virtual": {
      "import": "./dist/virtual.js",
      "types": "./dist/virtual/index.d.ts"
    },
    "./jsx-runtime": {
      "import": "./dist/jsx-runtime.js",
      "types": "./jsx-runtime.d.ts"
    },
    "./jsx-dev-runtime": {
      "import": "./dist/jsx-dev-runtime.js",
      "types": "./jsx-dev-runtime.d.ts"
    },
    "./hmr": {
      "import": "./dist/hmr.js",
      "types": "./dist/core/hmr.d.ts"
    },
    "./vite-plugin": {
      "import": "./vite-plugin.js"
    }
  },
  "files": [
    "dist",
    "*.d.ts",
    "vite-plugin.js"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "csstype": "^3.2.3",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
